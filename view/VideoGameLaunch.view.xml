<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m"
	controllerName="web.app.theCuriousDude.controller.VideoGameLaunch" xmlns:html="http://www.w3.org/1999/xhtml">
	<App>
		<pages>
			<Page title="{i18n>aboutVideoGame}">
				<content>
					<Text id="introVideoGame" text="{i18n>introVideoGame}" class="sapUiTinyMargin"/>
					<Image src="./img/videoGameBanner.jpg" decorative="true" width="100%"/>
					<MessageStrip text="{i18n>NoContentYet}" type="Information" showIcon="true"
						class="sapUiTinyMargin" />
				</content>
			</Page>
		</pages>
	</App>
</mvc:View>