<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" controllerName="web.app.theCuriousDude.controller.HomePage"
	xmlns:html="http://www.w3.org/1999/xhtml">
	<App>
		<pages>
			<Page title="{i18n>homeTitle}">
				<content>
					<GenericTile ariaLabel="envrionment" backgroundImage="./img/environementTileBg.jpg" class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="{i18n>environment}" subheader="{i18n>abouWorld}"
						press="navToNext">
						<TileContent>
							<Avatar src="sap-icon://e-care" backgroundColor="Accent8"/>
						</TileContent>
					</GenericTile>
					<GenericTile ariaLabel="tech" backgroundImage="./img/technologyTileBg.jpg" class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="{i18n>tech}" subheader="{i18n>aboutTech}"
						press="navToNext">
						<TileContent>
							<Avatar src="./img/robot.svg"/>
						</TileContent>
					</GenericTile>
					<GenericTile ariaLabel="transhumanism" backgroundImage="./img/transhumanismTileBg.jpg" class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="{i18n>transhumanism}" subheader="{i18n>aboutTranshumanism}"
						press="navToNext">
						<TileContent>
							<Avatar src="./img/brain.svg"/>
						</TileContent>
					</GenericTile>
					<GenericTile ariaLabel="travel" backgroundImage="./img/travelTileBg.jpg" class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="{i18n>travel}" subheader="{i18n>aboutTravel}"
						press="navToNext">
						<TileContent>
							<Avatar src="sap-icon://home-share"/>
						</TileContent>
					</GenericTile>
					<GenericTile ariaLabel="sport" backgroundImage="./img/sportTileBg.jpg" class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="{i18n>sport}" subheader="{i18n>aboutSport}"
						press="navToNext">
						<TileContent>
							<Avatar src="sap-icon://competitor"/>
						</TileContent>
					</GenericTile>
					<GenericTile ariaLabel="videoGame" backgroundImage="./img/videoGameTileBg.jpg" class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="{i18n>videoGame}" subheader="{i18n>aboutVideoGame}"
						press="navToNext">
						<TileContent>
							<Avatar src="./img/videogame.svg"/>
						</TileContent>
					</GenericTile>
					<GenericTile ariaLabel="boardGame" backgroundImage="./img/boardGametileBg.jpg" class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="{i18n>boardGame}" subheader="{i18n>aboutBoardGame}"
						press="navToNext">
						<TileContent>
							<Avatar src="./img/boardgames.svg"/>
						</TileContent>
					</GenericTile>
					<GenericTile ariaLabel="personalDevelopment" backgroundImage="./img/personalDevelopmentTileBg.jpg" class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="{i18n>persoDev}" subheader="{i18n>aboutPersoDev}"
						press="navToNext">
						<TileContent>
							<Avatar src="sap-icon://family-protection"/>
						</TileContent>
					</GenericTile>
					<GenericTile ariaLabel="aboutMe" backgroundImage="./img/aboutMeTileBg.jpg" class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="{i18n>aboutMe}" subheader="{i18n>myName}"
						press="navToNext">
						<TileContent>
							<Avatar src="./img/Sylvain.jpg"/>
						</TileContent>
					</GenericTile>
				</content>
			</Page>
		</pages>
	</App>
</mvc:View>