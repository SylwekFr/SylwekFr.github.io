{
    "_version": "1.12.0",
    "sap.app": {
        "id": "web.app.theCuriousDude",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "1.0.0"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "sourceTemplate": {
            "id": "ui5template.basicSAPUI5ApplicationProject",
            "version": "1.40.12"
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "",
            "favIcon": "",
            "phone": "",
            "phone@2": "",
            "tablet": "",
            "tablet@2": ""
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": false,
        "rootView": {
            "viewName": "web.app.theCuriousDude.view.App",
            "type": "XML",
            "async": true,
            "id": "App"
        },
        "dependencies": {
            "minUI5Version": "1.65.6",
            "libs": {
                "sap.ui.layout": {},
                "sap.ui.core": {},
                "sap.m": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "web.app.theCuriousDude.i18n.i18n"
                }
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "routing": {
            "config": {
                "routerClass": "sap.m.routing.Router",
                "viewType": "XML",
                "async": true,
                "viewPath": "web.app.theCuriousDude.view",
                "controlAggregation": "pages",
                "controlId": "app",
                "clearControlAggregation": false
            },
            "routes": [
                {
                    "name": "homePage",
                    "pattern": "",
                    "target": [
                        "homePage"
                    ]
                },
                {
                    "name": "environementLaunch",
                    "pattern": "environementLaunch",
                    "target": [
                        "environementLaunch"
                    ]
                },
                {
                    "name": "techLaunch",
                    "pattern": "techLaunch",
                    "target": [
                        "techLaunch"
                    ]
                },
                {
                    "name": "transhumanismLaunch",
                    "pattern": "transhumanismLaunch",
                    "target": [
                        "transhumanismLaunch"
                    ]
                },
                {
                    "name": "travelLaunch",
                    "pattern": "travelLaunch",
                    "target": [
                        "travelLaunch"
                    ]
                },
                {
                    "name": "sportLaunch",
                    "pattern": "sportLaunch",
                    "target": [
                        "sportLaunch"
                    ]
                },
                {
                    "name": "videoGameLaunch",
                    "pattern": "videoGameLaunch",
                    "target": [
                        "videoGameLaunch"
                    ]
                },
                {
                    "name": "boardGameLaunch",
                    "pattern": "boardGameLaunch",
                    "target": [
                        "boardGameLaunch"
                    ]
                },
                {
                    "name": "personalDevelopmentLaunch",
                    "pattern": "personalDevelopmentLaunch",
                    "target": [
                        "personalDevelopmentLaunch"
                    ]
                },
                {
                    "name": "aboutMe",
                    "pattern": "aboutMe",
                    "target": [
                        "aboutMe"
                    ]
                }
            ],
            "targets": {
                "homePage": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "homePage",
                    "viewName": "HomePage"
                },
                "environementLaunch": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "environementLaunch",
                    "viewName": "EnvironementLaunch"
                },
                "techLaunch": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "techLaunch",
                    "viewName": "TechLaunch"
                },
                "transhumanismLaunch": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "transhumanismLaunch",
                    "viewName": "TranshumanismLaunch"
                },
                "travelLaunch": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "travelLaunch",
                    "viewName": "TravelLaunch"
                },
                "sportLaunch": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "sportLaunch",
                    "viewName": "SportLaunch"
                },
                "videoGameLaunch": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "videoGameLaunch",
                    "viewName": "VideoGameLaunch"
                },
                "boardGameLaunch": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "boardGameLaunch",
                    "viewName": "BoardGameLaunch"
                },
                "personalDevelopmentLaunch": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "personalDevelopmentLaunch",
                    "viewName": "PersonalDevelopmentLaunch"
                },
                "aboutMe": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "aboutMe",
                    "viewName": "AboutMe"
                }
            }
        }
    }
}