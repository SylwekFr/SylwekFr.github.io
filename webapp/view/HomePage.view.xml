<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" controllerName="web.app.theCuriousDude.controller.HomePage"
	xmlns:html="http://www.w3.org/1999/xhtml">
	<App>
		<pages>
			<Page title="{i18n>homeTitle}">
				<content>
					<FlexBox items="{homeTiles>/}" wrap="Wrap">
						<GenericTile ariaLabel="{homeTiles>label}" backgroundImage="{homeTiles>background}"
							class="sapUiTinyMarginBegin sapUiTinyMarginTop tileLayout" header="{ path : 'homeTiles>header', formatter : '.formatter.getI18nValue' }" subheader="{path : 'homeTiles>subheader', formatter : '.formatter.getI18nValue' }" press="navToNext">
							<TileContent>
								<Avatar src="{homeTiles>icon}" backgroundColor="Accent8"/>
							</TileContent>
						</GenericTile>
					</FlexBox>
				</content>
			</Page>
		</pages>
	</App>
</mvc:View>